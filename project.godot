; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="MyWorld"
config/description="2D Open World with Pseudo-Height Terrain System"
config/version="0.1.0"
run/main_scene="res://Scenes/World/World.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SignalBus="*res://Scripts/autoload/SignalBus.gd"
SaveSystem="*res://Scripts/autoload/SaveSystem.gd"
InputManager="*res://Scripts/autoload/InputManager.gd"
RegionDatabase="*res://Scripts/autoload/RegionDatabase.gd"
Console="*res://addons/godot-console/scripts/console.gd"
PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"
BetterTerrain="*res://addons/better-terrain/BetterTerrain.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/better-terrain/plugin.cfg", "res://addons/godot-console/plugin.cfg", "res://addons/godot-sqlite/plugin.cfg", "res://addons/godot_mcp/plugin.cfg", "res://addons/godot_state_charts/plugin.cfg", "res://addons/phantom_camera/plugin.cfg")

